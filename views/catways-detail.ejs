<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Détail Catway — Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav>
    <span style="color:white; font-weight:bold;">⚓ Port Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/reservations">Réservations</a>
      <a href="/utilisateurs">Utilisateurs</a>
      <a href="/api-docs">Documentation</a>
      <a href="/logout">Déconnexion</a>
    </div>
  </nav>

  <div class="dashboard">
    <a href="/catways" class="btn btn-primary" style="margin-bottom:20px; display:inline-block;">← Retour</a>
    <h1>Catway n°<%= catway.catwayNumber %></h1>

    <div class="card" style="padding:20px; background:white; border-radius:8px; margin-bottom:20px;">
      <p><strong>Type :</strong> <%= catway.catwayType %></p>
      <p><strong>État :</strong> <%= catway.catwayState %></p>
    </div>

    
    <div class="card" style="padding:20px; background:white; border-radius:8px;">
      <h2>Modifier l'état</h2>
      <form action="/catways/<%= catway._id %>?_method=PUT" method="POST">
        <div class="form-group">
          <label>Nouvel état</label>
          <input type="text" name="catwayState" value="<%= catway.catwayState %>" required>
        </div>
        <button type="submit" class="btn btn-success">Mettre à jour</button>
      </form>
    </div>
  </div>

</body>
</html>
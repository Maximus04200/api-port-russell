<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>⚓ Port de Plaisance Russell</h1>
    <p>Bienvenue sur l'application de gestion des catways et réservations du port Russell.</p>

    <div class="card">
      <h2>Connexion</h2>
      <% if (typeof error !== 'undefined') { %>
        <p class="error"><%= error %></p>
      <% } %>
      <form action="/login" method="POST">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" required placeholder="votre@email.fr">
        </div>
        <div class="form-group">
          <label>Mot de passe</label>
          <input type="password" name="password" required placeholder="••••••">
        </div>
        <button type="submit">Se connecter</button>
      </form>
    </div>

    <a href="/api-docs" class="link">📄 Documentation de l'API</a>
  </div>
</body>
</html>